{
  "attribution": "<a href=\"https://github.com/sitmun\" target=\"_blank\">SITMUN</a>",
  "dashboard": {
    "allowedTypes": ["I"],
    "filteringEnabled": true
  },
  "defaultLanguage": "es",
  "languages": [
    { "name": "Español", "shortname": "es", "icon": "assets/flags/spain.svg" },
    {
      "name": "English",
      "shortname": "en",
      "icon": "assets/flags/united-kingdom.svg"
    },
    {
      "name": "Français",
      "shortname": "fr",
      "icon": "assets/flags/france.svg"
    },
    { "name": "Català", "shortname": "ca", "icon": "assets/flags/catalan.svg" },
    {
      "name": "Aranés",
      "shortname": "oc-aranes",
      "icon": "assets/flags/val-aran.svg"
    }
  ],
  "enabledByDefault": ["sitna.multiFeatureInfo"],
  "controlDefaults": {
    "sitna.coordinates": {
      "div": "coordinates"
    },
    "sitna.scale": {
      "div": "scale"
    },
    "sitna.scaleBar": {
      "div": "scale"
    },
    "sitna.scaleSelector": {
      "div": "scale"
    },
    "sitna.workLayerManager": {
      "div": "wlm"
    },
    "sitna.layerCatalog": {
      "div": "toc",
      "enableSearch": true
    },
    "sitna.basemapSelector": {
      "div": "bms"
    },
    "sitna.legend": {
      "div": "legend"
    },
    "sitna.dataLoader": {
      "div": "xdata"
    },
    "sitna.download": {
      "div": "download"
    },
    "sitna.drawMeasureModify": {
      "div": "drawmeasuremodify"
    },
    "sitna.fullScreen": {
      "div": "FuScreen"
    },
    "sitna.geolocation": {
      "div": "geolocation"
    },
    "sitna.measure": {
      "div": "measure"
    },
    "sitna.multiFeatureInfo": {
      "div": "multifeatureinfo"
    },
    "sitna.offlineMapMaker": {
      "div": "offline"
    },
    "sitna.printMap": {
      "div": "print",
      "logo": "assets/logos/logo_orange.png",
      "legend": {
        "visible": true
      }
    },
    "sitna.navBar": {
      "div": "nav"
    },
    "sitna.overviewMap": {
      "div": "ovmap"
    },
    "sitna.search": {
      "div": "search"
    },
    "sitna.layerCatalog.silme.extension": {
      "div": "catalog"
    },
    "sitna.featureInfo.silme.extension": {
      "persistentHighlights": true
    },
    "sitna.threed": {
      "controls": [
        "sitna.threed",
        "sitna.navBar",
        "sitna.navBarHome",
        "sitna.basemapSelector",
        "sitna.layerCatalog",
        "sitna.scaleSelector",
        "sitna.printMap",
        "sitna.workLayerManager",
        "sitna.legend"
      ]
    }
  }
}
