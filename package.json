  "version": "1.2.5",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "export NODE_OPTIONS=\"--openssl-legacy-provider --max-old-space-size=8192\" && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "ng lint",
    "format": "npx prettier --write src",
    "clean": "bash scripts/clean.sh",
    "clean:force": "bash scripts/clean.sh --force",
    "clean:build": "bash scripts/clean.sh --build-only",
    "postinstall": "node scripts/patch-printmap-logo.js"
  },
  "private": true,
  "engines": {
    "node": ">=20.19.0"
