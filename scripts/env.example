# Environment Configuration Template for SITMUN Viewer App
# Copy this file to .env and fill in the values
# Note: .env files should NOT be committed to version control

# GitHub Pages Deployment
# Required for deployment scripts
GITHUB_API_KEY=your_github_token_here
USERNAME=your_github_username

# Build Configuration
# Base href for GitHub Pages deployment
BASE_HREF=https://sitmun.github.io/sitmun-viewer-app/

# CI/CD Environment Variables
# These are automatically set in GitHub Actions, but can be set locally for testing
GITHUB_WORKSPACE=${PWD}
CI=false
